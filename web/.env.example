# ── Web app (Vercel) environment ──────────────────────────────────────────
# Copy to `.env.local` for local dev. In Vercel, set this in
# Project → Settings → Environment Variables for Production + Preview + Development.
#
# `NEXT_PUBLIC_*` vars are inlined into the client bundle at BUILD time,
# so after changing them you must redeploy.

# Public AWS HTTP API base URL — NOT a secret.
# PREFER the CloudFront edge-cache URL (terraform output `cloudfront_api_url`):
# it serves the public feed reads (/feed, /pins, /recommendations, /ideas) from
# the edge WITHOUT invoking the Lambda, protecting the small concurrency pool from
# the throttling those reads were causing. The raw API Gateway URL below is the
# CloudFront origin and also works directly (uncached) as a fallback.
#NEXT_PUBLIC_API_URL=https://<distribution-id>.cloudfront.net
NEXT_PUBLIC_API_URL=https://tvyu8gqmki.execute-api.us-east-1.amazonaws.com

# Canonical public URL of the deployed app (no trailing slash). Used to build
# share / invite links so they always point at PRODUCTION — never a Vercel
# *preview* deployment, which sits behind Vercel Authentication and would force
# the recipient to "log in to Vercel". Leave blank for local dev (falls back to
# the current origin). Example: https://giftmaxxing.vercel.app
NEXT_PUBLIC_SITE_URL=

# Amazon Associates affiliate tag (public; appended to outbound Amazon links).
# Defaults to the committed tag if unset.
NEXT_PUBLIC_AMAZON_ASSOC_TAG=giftmaxxingde-20

# ── Amazon OneLink (optional) — international link localization ────────────
# OneLink rewrites our US-tagged outbound links so each visitor lands on THEIR
# local store (amazon.in, amazon.co.uk, …) with OUR local tag, so we earn in
# that marketplace. Prerequisites, all in Associates Central:
#   1. Be an approved Associate in each target store (join Amazon India at
#      affiliate-program.amazon.in → you get a `-21` tag).
#   2. Link your tracking IDs across stores under Tools → OneLink.
#   3. Paste the adInstanceId GUID from the snippet it generates below.
# The script stays OFF until the instance ID is set. Home marketplace stays US.
#NEXT_PUBLIC_AMAZON_ONELINK_INSTANCE_ID=00000000-0000-0000-0000-000000000000
#NEXT_PUBLIC_AMAZON_ONELINK_MARKETPLACE=US

# ── Skimlinks (affiliate aggregator) — non-Amazon retailer monetization ────
# Skimlinks rewrites outbound NON-Amazon retailer links (Sephora, Urban
# Outfitters, Target, …) into commission-tracked links at click time, via one
# Skimlinks approval — no need to join each brand program directly. The publisher
# id is PUBLIC (it ships in the script URL) and defaults to the committed id in
# components/skimlinks.tsx. Override it here, or set it to empty to DISABLE the
# script. Prereq: add your production domain as a site in the Skimlinks dashboard
# (localhost / Vercel previews are not rewritten).
#NEXT_PUBLIC_SKIMLINKS_ID=305299X1793495

# ── Amazon Product Advertising API (PA-API) — enrichment script ONLY ──────
# Used by `node infra/ingest/paapi-enrich.mjs` to pull OFFICIAL product images,
# titles, and details into web/lib/amazon-picks.json — the only compliant source
# (NEVER scrape Amazon pages). Requires PA-API access, which Amazon grants after
# ~3 qualifying sales within 180 days. SECRET: do NOT prefix NEXT_PUBLIC_ and do
# NOT add to Vercel — the browser never calls PA-API. Put these in repo-root .env:
#AMAZON_PAAPI_ACCESS_KEY=
#AMAZON_PAAPI_SECRET_KEY=
#AMAZON_PARTNER_TAG=giftmaxxingde-20
#AMAZON_PAAPI_HOST=webservices.amazon.com
#AMAZON_PAAPI_REGION=us-east-1

# ── Clerk authentication (optional) ──────────────────────────────────────
# When both keys are set, Clerk auth is enabled (sign-in/up, user sessions,
# cloud profile sync). When absent, the app degrades gracefully — all
# features work except authentication.
# Get these from https://dashboard.clerk.com → your app → API Keys.
#NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
#CLERK_SECRET_KEY=sk_test_...

# ── API authentication ───────────────────────────────────────────────────
# Protected API endpoints (your data: profile, events, connections, taste,
# Maxi) require a signed-in Clerk session — attached automatically by the app
# once the Clerk keys above are configured. Public catalog endpoints (feed,
# search, recommendations) need nothing. Local-only dev tooling, if any, is
# configured in your gitignored .env.local — not here.

# ── DO NOT put any of these in Vercel ─────────────────────────────────────
# The browser never talks to AWS directly. The API Lambda accesses the
# database/storage server-side via its IAM role, so these stay out of the
# frontend entirely (no NEXT_PUBLIC_ prefix, not in Vercel):
#   - AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_SESSION_TOKEN
#   - DynamoDB table names (posts / knowledge / interactions / users)
#   - S3 bucket names (media) and S3 Vectors bucket/index (vectors / pins)
#   - Bedrock model IDs, PINTEREST_API_KEY, REDDIT_* credentials
