# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# ── Reddit API (gift scraper: web/scripts/scrape-reddit.mjs) ──
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=

# ── Pinterest API (taste signals; OAuth 2.0, user-scoped content) ──
# Rate limits: Trial = 1000 req/day, Standard = 100 req/sec. See ../CLOUD.md §1.
PINTEREST_API_KEY=
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URI=

# ── AWS image → vector pipeline (Bedrock multimodal embeddings) — see CLOUD.md ──
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-image-v1
MEDIA_BUCKET=giftmaxxing-dev-media

# ── Future: visual search affiliate enrich (Amazon/Walmart) — CLOUD.md §6 ──
AMAZON_ASSOCIATES_ACCESS_KEY=
AMAZON_ASSOCIATES_SECRET_KEY=
AMAZON_ASSOCIATES_PARTNER_TAG=
WALMART_AFFILIATE_CONSUMER_ID=
WALMART_AFFILIATE_PRIVATE_KEY=

# ── AWS credentials ──
# Prefer a named SSO profile (`aws configure sso`) over static keys.
# If you must use temporary credentials, paste them here (they expire):
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
