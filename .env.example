# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# ── Reddit API (gift scraper: web/scripts/scrape-reddit.mjs) ──
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=

# ── Pinterest API (taste signals) ──
PINTEREST_API_KEY=

# ── AWS credentials ──
# Prefer a named SSO profile (`aws configure sso`) over static keys.
# If you must use temporary credentials, paste them here (they expire):
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
