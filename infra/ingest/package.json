{
  "name": "giftmaxxing-ingest",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Reddit -> DynamoDB ingestion pipeline for Giftmaxxing posts",
  "scripts": {
    "dry-run": "node ingest.mjs --dry-run",
    "ingest": "node ingest.mjs",
    "scrape:pinterest:dry": "node pinterest-rss.mjs --dry-run",
    "scrape:pinterest": "node pinterest-rss.mjs",
    "vectors:setup": "node s3vectors-setup.mjs",
    "embed": "node embed.mjs",
    "vectors:query": "node vector-query.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.600.0",
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/client-s3vectors": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0"
  }
}
