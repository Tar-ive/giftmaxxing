{
  "name": "giftmaxxing-ingest",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Reddit -> DynamoDB ingestion pipeline for Giftmaxxing posts",
  "scripts": {
    "dry-run": "node ingest.mjs --dry-run",
    "ingest": "node ingest.mjs",
    "scrape:pinterest:dry": "node pinterest-rss.mjs --dry-run",
    "scrape:pinterest": "node pinterest-rss.mjs",
    "scrape:dry": "node pinterest-scrape.mjs --target 200 --dry-run",
    "scrape": "node pinterest-scrape.mjs --target 10000",
    "scrape:resume": "node pinterest-scrape.mjs --target 10000 --resume",
    "scrape:retailers:dry": "node pinterest-scrape.mjs --target 60 --retailers --require-price --dry-run --out pins.retailers.json --state .scrape-retailers.state.json",
    "scrape:retailers": "node pinterest-scrape.mjs --target 3000 --retailers --require-price --out pins.retailers.json --state .scrape-retailers.state.json",
    "vectors:setup": "node s3vectors-setup.mjs",
    "embed": "node embed.mjs",
    "ingest:pins:dry": "node ingest-pins.mjs --dry-run",
    "ingest:pins": "node ingest-pins.mjs",
    "clean:posts:dry": "node clean-posts.mjs",
    "clean:posts": "node clean-posts.mjs --apply",
    "vectors:query": "node vector-query.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.600.0",
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/client-s3vectors": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0"
  }
}
